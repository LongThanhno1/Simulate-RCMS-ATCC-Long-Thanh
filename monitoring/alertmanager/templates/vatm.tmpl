{{/* ============================================================
     VATM ATCC Long Thành — Alertmanager Telegram Templates
     Park Air VHF System | ED-137 Compliant
     ============================================================
     Templates Go cho các loại cảnh báo:
       - vatm.telegram.critical   : Sự cố nghiêm trọng
       - vatm.telegram.warning    : Cảnh báo ngưỡng
       - vatm.telegram.ed137      : Vi phạm chuẩn ED-137
       - vatm.telegram.resolved   : Sự cố đã khắc phục
     ============================================================ */}}

{{/* ─── Helper: Icon theo severity ─── */}}
{{ define "vatm.icon.severity" -}}
  {{- if eq .CommonLabels.severity "critical" }}🔴{{ end -}}
  {{- if eq .CommonLabels.severity "warning" }}🟡{{ end -}}
  {{- if eq .CommonLabels.severity "info" }}🔵{{ end -}}
{{- end }}

{{/* ─── Helper: Tên trạm theo site label ─── */}}
{{ define "vatm.site.name" -}}
  {{- if eq .CommonLabels.site "tx" }}📡 Trạm TX (Long Thành){{ end -}}
  {{- if eq .CommonLabels.site "rx" }}📻 Trạm RX (Long Thành){{ end -}}
  {{- if eq .CommonLabels.site "ubvhf" }}🏢 UBVHF Tầng 20 TWR{{ end -}}
  {{- if eq .CommonLabels.site "atcc" }}🗼 ATCC Long Thành{{ end -}}
  {{- if not .CommonLabels.site }}📍 {{ .CommonLabels.instance }}{{ end -}}
{{- end }}

{{/* ─── Helper: Thời gian định dạng Việt Nam ─── */}}
{{ define "vatm.time" -}}
  {{- (.StartsAt.In (now.Location)).Format "02/01/2006 15:04:05 MST" -}}
{{- end }}

{{/* ============================================================
     Template 1: CRITICAL — Sự cố nghiêm trọng
     Dùng cho: thiết bị down, mất kết nối, S4-IP TCP fail
     ============================================================ */}}
{{ define "vatm.telegram.critical" -}}
🔴 *CẢNH BÁO KHẨN | VATM ATCC LONG THÀNH*

{{ template "vatm.site.name" . }}
⏰ `{{ (index .Alerts 0).StartsAt.Format "02/01/2006 15:04:05" }} UTC`

{{- range .Alerts }}
━━━━━━━━━━━━━━━━━━━━
🚨 *{{ .Labels.alertname }}*
📌 Thiết bị: `{{ .Labels.instance | reReplaceAll ":[0-9]+" "" }}`
{{- if .Labels.job }}
🔧 Job: `{{ .Labels.job }}`
{{- end }}
{{- if .Annotations.summary }}
📋 Tóm tắt: {{ .Annotations.summary }}
{{- end }}
{{- if .Annotations.description }}
📝 Chi tiết: {{ .Annotations.description }}
{{- end }}
{{- if .Annotations.runbook }}
📖 Xử lý: {{ .Annotations.runbook }}
{{- end }}
{{- end }}

━━━━━━━━━━━━━━━━━━━━
🔗 [Grafana](http://192.168.100.10:3000) | [Alertmanager](http://192.168.100.10:9093)
⚠️ _Yêu cầu xử lý ngay — ảnh hưởng an toàn hàng không_
{{- end }}


