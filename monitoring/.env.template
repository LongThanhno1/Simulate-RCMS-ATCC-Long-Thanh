# ─────────────────────────────────────────────────────────
# CẤU HÌNH HẠ TẦNG
# ─────────────────────────────────────────────────────────

# IP của VM1 chạy Docker stack (dùng cho external-url các service)
# Lab:        192.168.100.10
# Production: IP thực của máy chủ RCMS
MONITOR_HOST=192.168.100.10

# ─────────────────────────────────────────────────────────
# GRAFANA CREDENTIALS
# ─────────────────────────────────────────────────────────

# Tài khoản admin Grafana (đổi password mạnh trước khi dùng)
GRAFANA_ADMIN_USER=vatm_admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─────────────────────────────────────────────────────────
# TELEGRAM BOT — Cảnh báo thời gian thực
# ─────────────────────────────────────────────────────────
# Hướng dẫn lấy token:
#   1. Nhắn tin @BotFather trên Telegram
#   2. Gõ /newbot → đặt tên → nhận token dạng: 1234567890:ABC-DEF...
#   3. Điền token vào TELEGRAM_BOT_TOKEN bên dưới

TELEGRAM_BOT_TOKEN=8939180820:AAFI3EuI0FYToF2ZuskGi7zwuONReEqQFx8

# Hướng dẫn lấy Chat ID:
#   1. Thêm bot vào group cảnh báo (hoặc nhắn trực tiếp với bot)
#   2. Gửi 1 tin nhắn bất kỳ trong group
#   3. Truy cập: https://api.telegram.org/bot<TOKEN>/getUpdates
#   4. Tìm "chat":{"id": -XXXXXXXXX} → đó là Chat ID (số âm = group)
#
# Lưu ý: Chat ID là số nguyên, có thể âm (group) hoặc dương (cá nhân)
# Ví dụ group: -1001234567890  |  Cá nhân: 123456789

TELEGRAM_CHAT_ID=REPLACE_WITH_CHAT_ID

